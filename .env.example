APP_NAME=Laravel
SELF_UPDATER_VERSION_INSTALLED=v1.4.0-alpha
SELF_UPDATER_PACKAGE_FILE_NAME=streamer-release.zip
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=14
TWITCH_LOG_DAILY_DAYS=14
LOG_VIEWER_MAX_SIZE_KB=2048
SELF_UPDATER_LOG_PRUNING_ENABLED=true
SELF_UPDATER_LOG_MAX_SIZE_KB=1024
SELF_UPDATER_LOG_RETENTION_DAYS=14

# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# Persistent connections let php-fpm workers reuse sockets across requests.
# Recommended on managed MySQL (e.g. DigitalOcean) where the connection cap
# is small. Leave false on shared-hosting where the DB is on a local socket.
# DB_PERSISTENT=true
# Seconds to wait when opening a new connection before giving up.
# DB_TIMEOUT=5
# Seconds an idle MySQL session stays open before the server reaps it.
# Lower this when you're hitting "Too many connections" — a leaked
# connection then can't hold a slot forever.
# DB_WAIT_TIMEOUT=60

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
COOKIE_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_READ_WRITE_TIMEOUT=-1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

NEWSLETTER_API_KEY=your-mailchimp-key
NEWSLETTER_LIST_ID=your-mailchimp-list-id

# S3 / S3-compatible object storage (AWS S3, DigitalOcean Spaces, MinIO, R2, etc.)
# Leave blank to keep using local storage — S3 is opt-in.
# To enable: fill in credentials below, then set MEDIA_DISK=s3 (and optionally
# UPLOAD_DISK=s3 / FILESYSTEM_DISK=s3).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_ENDPOINT — set for S3-compatible providers.
# DigitalOcean Spaces example: https://nyc3.digitaloceanspaces.com
#   (regions: nyc1, nyc3, sfo2, sfo3, ams3, sgp1, fra1, syd1, blr1)
# Leave blank for AWS S3 itself.
AWS_ENDPOINT=
# AWS_URL — public URL base for served assets (CDN domain or bucket URL).
# DO Spaces CDN example: https://<bucket>.<region>.cdn.digitaloceanspaces.com
# DO Spaces direct example: https://<bucket>.<region>.digitaloceanspaces.com
AWS_URL=

# Spatie Media Library disk — defaults to "public" (local). Set to "s3" to store
# uploads on S3. Switching has no effect until AWS_* credentials above are set.
MEDIA_DISK=public

# Default disk for Filament admin file uploads (post images, product images,
# hero banners, etc.). Defaults to MEDIA_DISK so a single MEDIA_DISK=s3 flips
# everything. Override here only if you want admin uploads on a different disk
# than Media Library.
UPLOAD_DISK=

# ASSET_URL — prepended to URLs generated by asset() and the Vite helper.
# Leave blank to serve public/ assets from this app. Set to your CDN origin to
# serve public/build, public/vendor, etc. from S3/CDN after running
# `php artisan storage:migrate-to-s3 --public`.
ASSET_URL=

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CREDENTIALS=

FOURTHWALL_STOREFRONT_TOKEN=
FOURTHWALL_STOREFRONT_URL=
FOURTHWALL_VERIFY=true
FOURTHWALL_DEFAULT_PRODUCT_IMAGE='/products/default.jpg'
FOURTHWALL_OPEN_API_KEY=
FOURTHWALL_OPEN_API_SECRET=
FOURTHWALL_WEBHOOK_SECRET=

STRIPE_ENABLE=false
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=USD
STRIPE_MIN_DONATION=1
STRIPE_MAX_DONATION=10000

DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=

TWITCH_ENABLED=false
TWITCH_CHANNEL=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_OAUTH_REDIRECT=
TWITCH_VERIFY=

X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=
X_SCOPES="tweet.read tweet.write users.read offline.access"

AKISMET_APIKEY=
AKISMET_BLOGURL=

# In production, you will require Turnstile keys, both of them obtainable through your Cloudflare Dashboard
TURNSTILE_ENV=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

MAXMIND_KEY=
MAXMIND_ACCOUNT_ID=

ABUSEIP_DB_KEY=
